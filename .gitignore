# ============================================================
# ns3-miot-simulation — .gitignore
# ============================================================

# --- ns-3 / C++ build artifacts ---
*.o
*.a
*.so
*.lo
*.la
*.pcap
*.xml
build/
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
compile_commands.json

# --- Python ---
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
.pytest_cache/
.ipynb_checkpoints/
.venv/
venv/
env/

# --- Editors / IDEs ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS junk ---
.DS_Store
Thumbs.db

# --- Local scratch / temp ---
*.tmp
scratch_*/
local_*

# --- Large redundant archives (use `git add -f <file>` to force-add) ---
/*.zip
